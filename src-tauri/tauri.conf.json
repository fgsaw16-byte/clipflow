{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clipflow",
  "version": "3.1.6",
  "identifier": "com.alex.clipflow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClipFlow",
        "label": "main",
        "width": 360,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
